# ============================================================================
# SMART RAG - ENVIRONMENT TEMPLATE FILE
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# This .env.example is safe to share/commit - it contains NO real secrets
# The actual .env file (with your keys) should NEVER be shared
# ============================================================================

# ============================================================================
# LLM SELECTION
# ============================================================================
# Choose which AI model to use:
#   - openai (best quality, needs paid API)
#   - gemini (Google, free tier available)
#   - openrouter (cheap, supports many models)
#
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# Cost: Pay-as-you-go (approximately $0.01-$0.10 per query)
# Sign up: https://platform.openai.com/signup
#
OPENAI_API_KEY=sk-your-actual-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# GOOGLE GEMINI CONFIGURATION
# ============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
# Cost: Free tier available (50 requests/day), paid for more
# Sign up: https://makersuite.google.com
#
GOOGLE_API_KEY=your-actual-gemini-key-here
GEMINI_MODEL=gemini-1.5-pro

# ============================================================================
# OPENROUTER CONFIGURATION (RECOMMENDED FOR COST)
# ============================================================================
# Get your API key from: https://openrouter.ai/keys
# Cost: Very cheap (from $0.000005 per query)
# Sign up: https://openrouter.ai
# Popular models available from multiple providers
#
OPENROUTER_API_KEY=sk-or-your-actual-key-here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# ============================================================================
# EMBEDDING CONFIGURATION
# ============================================================================
# Which model to use for document embeddings
# Default is recommended unless you have specific needs
#
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================================================
# DATA FOLDERS
# ============================================================================
# Where documents and database are stored
# Auto-created if they don't exist
# For cloud: adjust paths as needed
#
DATA_FOLDER=backend/data
VECTOR_STORE_PATH=backend/data/faiss_index
DATABASE_PATH=backend/data/rag_pipeline.db

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Host and port for the API server
# For cloud: use 0.0.0.0 and your cloud provider's port
#
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

# ============================================================================
# CLOUD-SPECIFIC SETTINGS (optional)
# ============================================================================
# Uncomment and modify if deploying to cloud

# For AWS, Azure, GCP storage:
# STORAGE_TYPE=cloud  # or 'local' (default)
# CLOUD_STORAGE_BUCKET=your-bucket-name
# CLOUD_STORAGE_PATH=/rag_data

# For persistent data on cloud:
# ENABLE_CLOUD_STORAGE=true
# CLOUD_PROVIDER=aws  # aws, azure, or gcp

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# If you see errors about missing keys:
# 1. Replace 'your-xxx-key-here' with actual API keys
# 2. Don't include quotes around the key value
# 3. Use 'openai', 'gemini', or 'openrouter' as LLM_PROVIDER
# 4. Restart the application
#
# If documents aren't being found:
# 1. Check that DATA_FOLDER path is correct
# 2. Ensure the folder has write permissions
# 3. For cloud: use absolute path or cloud storage
#
# ============================================================================
